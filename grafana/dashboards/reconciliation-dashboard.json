      "title": "IDs Missing in Handler",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://ai-observability:8000/grafana/reconcile/samples?kind=missingInHandler&hours=${reconcileHours}",
          "url_options": { "method": "GET" },
          "columns": [{ "selector": "paymentId", "text": "paymentId", "type": "string" }],
          "parser": "backend",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
      "description": "Payments that were handler-published but never got final status update back to initiation (up to 20 samples).",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "custom": { "align": "left", "cellOptions": { "type": "auto" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "paymentId" }, "properties": [{ "id": "custom.width", "value": 280 }] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 32,
      "options": { "footer": { "show": false }, "showHeader": true, "cellHeight": "sm" },
      "title": "IDs Missing Status Update",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://ai-observability:8000/grafana/reconcile/samples?kind=missingStatusUpdate&hours=${reconcileHours}",
          "url_options": { "method": "GET" },
          "columns": [{ "selector": "paymentId", "text": "paymentId", "type": "string" }],
          "parser": "backend",
          "format": "table"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "Live Payment Log Stream",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 33 },
      "id": 40,
      "options": { "showTime": true, "showLabels": false, "showCommonLabels": false, "wrapLogMessage": false, "prettifyLogMessage": false, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "title": "Live Log Stream — All Services",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "refId": "A",
          "expr": "{job=\"payment-services\"} |= \"paymentId=PAY\"",
          "legendFormat": ""
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["payment", "reconciliation"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "1", "value": "1" },
        "hide": 0,
        "name": "reconcileHours",
        "label": "Lookback (hours)",
        "options": [
          { "selected": true, "text": "1", "value": "1" },
          { "selected": false, "text": "3", "value": "3" },
          { "selected": false, "text": "6", "value": "6" },
          { "selected": false, "text": "12", "value": "12" },
          { "selected": false, "text": "24", "value": "24" }
        ],
        "query": "1,3,6,12,24",
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
