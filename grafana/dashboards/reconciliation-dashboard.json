          "source": "url",
          "url": "http://ai-observability:8000/grafana/reconcile/summary?hours=${reconcileHours}",
          "url_options": { "method": "GET" },
          "columns": [{ "selector": "missingInRouter", "text": "missingInRouter", "type": "number" }],
          "parser": "backend",
          "format": "table"
