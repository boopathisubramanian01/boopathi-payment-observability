    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Pipeline Flow — Bar Gauge",
      "type": "row"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
      "description": "Tracks how many payments made it through each stage of the pipeline.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 6 },
      "id": 10,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "valueMode": "color", "showUnfilled": true },
      "title": "Pipeline Stage Counts",
      "type": "bargauge",
      "targets": [
        {
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://ai-observability:8000/grafana/reconcile/summary?hours=${reconcileHours}",
          "url_options": { "method": "GET" },
          "columns": [
            { "selector": "initiationPublished", "text": "1-Initiation Published", "type": "number" },
            { "selector": "routerProcessed", "text": "2-Router Processed", "type": "number" },
            { "selector": "routerProcessedInstant", "text": "3-Router (Instant)", "type": "number" },
            { "selector": "routerProcessedNonInstant", "text": "4-Router (Non-Instant)", "type": "number" },
            { "selector": "handlerPublished", "text": "5-Handler Published", "type": "number" },
            { "selector": "initiationStatusUpdated", "text": "6-Status Updated", "type": "number" }
          ],
          "parser": "backend",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
      "description": "Gaps in the pipeline that need investigation.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 6 },
      "id": 11,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "lcd", "valueMode": "color", "showUnfilled": true },
      "title": "Reconciliation Gaps",
      "type": "bargauge",
      "targets": [
        {
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://ai-observability:8000/grafana/reconcile/summary?hours=${reconcileHours}",
          "url_options": { "method": "GET" },
          "columns": [
            { "selector": "missingInRouter", "text": "Missing in Router", "type": "number" },
            { "selector": "missingInHandler", "text": "Missing in Handler", "type": "number" },
            { "selector": "missingStatusUpdate", "text": "Missing Status Update", "type": "number" }
          ],
          "parser": "backend",
          "format": "table"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Payment Volume Over Time (Loki)",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Rate of payments initiated, routed, and handler-published per minute.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 15 },
      "id": 20,
      "options": { "tooltip": { "mode": "multi", "sort": "none" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Payment Events Rate (per min)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "refId": "Initiated",
          "expr": "sum(rate({service=\"payment-initiation-service\"} |= \"Kafka broker ACK confirmed\" [1m]))",
          "legendFormat": "Initiated"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "refId": "Routed",
          "expr": "sum(rate({service=\"payment-router\"} |= \"Payment routed successfully\" [1m]))",
          "legendFormat": "Routed"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "refId": "HandlerPublished",
          "expr": "sum(rate({service=\"instant-payment-handler\"} |= \"PAIN 002 published\" [1m]))",
          "legendFormat": "Handler Published"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "refId": "StatusUpdated",
          "expr": "sum(rate({service=\"payment-initiation-service\"} |= \"PAIN 002 status updated\" [1m]))",
          "legendFormat": "Status Updated"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Payments rejected or errored — spikes indicate routing issues.",
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "red", "mode": "fixed" }, "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 20 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "id": 21,
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Rejection Rate (per min)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "refId": "Rejected",
          "expr": "sum(rate({service=\"payment-router\"} |= \"Payment rejected\" [1m]))",
          "legendFormat": "Rejected"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Missing Payment ID Samples",
      "type": "row"
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
      "description": "Payment IDs that were initiated but never seen in router logs (up to 20 samples).",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "custom": { "align": "left", "cellOptions": { "type": "auto" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "paymentId" }, "properties": [{ "id": "custom.width", "value": 280 }] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 30,
      "options": { "footer": { "show": false }, "showHeader": true, "cellHeight": "sm" },
