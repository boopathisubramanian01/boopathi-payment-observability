      "type": "table",
      "targets": [
        {
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
          "refId": "A",
          "type": "json",
          "source": "url",
          "url": "http://ai-observability:8000/grafana/reconcile/samples?kind=missingInRouter&hours=${reconcileHours}",
          "url_options": { "method": "GET" },
          "columns": [{ "selector": "paymentId", "text": "paymentId", "type": "string" }],
          "parser": "backend",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
      "description": "Instant payments that reached the router but were never seen in handler logs (up to 20 samples).",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "custom": { "align": "left", "cellOptions": { "type": "auto" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "paymentId" }, "properties": [{ "id": "custom.width", "value": 280 }] }
